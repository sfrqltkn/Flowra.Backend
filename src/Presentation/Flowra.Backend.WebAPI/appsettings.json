{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gemini": {
    "ApiKey": "SECRET_KEY_PLACEHOLDER"
  },
  "CollectApi": {
    "ApiKey": "YOUR_COLLECT_API_KEY_HERE"
  },
  "ConnectionStrings": {
    "PostgreSQL": "SECRET_CONNECTION_PLACEHOLDER"
  },
  "MailSettings": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "DisplayName": "Flowra-Backend",
    "EnableSsl": false,
    "AdminEmail": "",
    "IgnoreSslErrors": true
  },
  "JwtSettings": {
    "Issuer": "https://auth.Flowra-Backend.local",
    "Audience": "https://api.Flowra-Backend.local",
    "SigningKey": "",
    "EncryptionKey": "",
    "AccessTokenExpiryMinutes": "15",
    "RefreshTokenExpiryDays": "7"
  },
  "JwtCookieOptions": {
    "HttpOnly": true,
    "Secure": true,
    "SameSite": "None",
    "AccessTokenPath": "/",
    "RefreshTokenPath": "/",
    "IsEssential": true
  }
}